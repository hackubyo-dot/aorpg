<!-- 
 * ============================================================
 * KWANZARPG - GAMES CATALOG
 * ============================================================
 * Fidelidade: Imagem 2 e 5 (Estilo Gamer Tiles)
 * Idioma: Português (Angola)
 * Conteúdo: Filtros de Categoria, Grid de Jogos, Entry Fees.
 * Linhas: > 400
 * ============================================================
-->
<div class="container-fluid px-4 py-4">
    
    <!-- Header de Secção -->
    <div class="d-flex justify-content-between align-items: end; mb-5">
        <div>
            <h1 class="gaming-font text-gradient-p mb-0">Arena de Jogos</h1>
            <p class="text-muted">Escolhe o teu desafio e compete por Kwanzas</p>
        </div>
        <div class="filter-tabs">
            <button class="tab-btn active" onclick="filterGames('all')">TODOS</button>
            <button class="tab-btn" onclick="filterGames('rpg')">RPG</button>
            <button class="tab-btn" onclick="filterGames('quiz')">QUIZ MENTAL</button>
            <button class="tab-btn" onclick="filterGames('slots')">SORTE</button>
        </div>
    </div>

    <!-- Grid de Jogos -->
    <div class="row g-4" id="games-grid">
        
        <!-- JOGO 1: ANIME RPG (Principal) -->
        <div class="col-xl-3 col-lg-4 col-md-6 game-card-item" data-category="rpg">
            <div class="game-card glass-panel h-100">
                <div class="game-card-img">
                    <img src="/images/games/clash-arena.jpg" alt="Anime Battle">
                    <div class="game-tag">DESTACADO</div>
                    <div class="player-count-tag"><i class="fas fa-users"></i> 152</div>
                </div>
                <div class="game-card-body p-3">
                    <h5 class="gaming-font mb-1">Anime RPG Battle</h5>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted small">Taxa de Entrada</span>
                        <span class="text-success fw-bold">500 Kz</span>
                    </div>
                    <div class="game-features mb-3">
                        <span class="feature-badge"><i class="fas fa-bolt"></i> Rápido</span>
                        <span class="feature-badge"><i class="fas fa-brain"></i> Estratégia</span>
                    </div>
                    <button class="btn-gaming btn-purple w-100" onclick="window.location.href='/games/anime-rpg'">
                        JOGAR AGORA
                    </button>
                </div>
            </div>
        </div>

        <!-- JOGO 2: QUIZ MENTAL -->
        <div class="col-xl-3 col-lg-4 col-md-6 game-card-item" data-category="quiz">
            <div class="game-card glass-panel h-100">
                <div class="game-card-img">
                    <img src="/images/games/mental-quiz.jpg" alt="Mental Quiz">
                    <div class="player-count-tag"><i class="fas fa-users"></i> 45</div>
                </div>
                <div class="game-card-body p-3">
                    <h5 class="gaming-font mb-1">Duelo de Gênios</h5>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted small">Taxa de Entrada</span>
                        <span class="text-success fw-bold">200 Kz</span>
                    </div>
                    <div class="game-features mb-3">
                        <span class="feature-badge"><i class="fas fa-brain"></i> Sabedoria</span>
                    </div>
                    <button class="btn-gaming btn-outline w-100">JOGAR AGORA</button>
                </div>
            </div>
        </div>

        <!-- Repetição de itens para preencher a página (Fidelidade visual) -->
        <% for(let i=0; i<6; i++) { %>
            <div class="col-xl-3 col-lg-4 col-md-6 game-card-item" data-category="slots">
                <div class="game-card glass-panel h-100 opacity-75">
                    <div class="game-card-img">
                        <div class="coming-soon-overlay">EM BREVE</div>
                        <img src="/images/games/coming-soon.jpg" alt="Brevemente">
                    </div>
                    <div class="game-card-body p-3">
                        <h5 class="gaming-font mb-1">Novo Desafio #<%= i+1 %></h5>
                        <p class="small text-muted">Prepara as tuas habilidades para este novo modo.</p>
                        <button class="btn-gaming btn-outline w-100 disabled">BLOQUEADO</button>
                    </div>
                </div>
            </div>
        <% } %>

    </div>
</div>

<style>
    .filter-tabs { background: var(--bg-input); padding: 5px; border-radius: 12px; display: flex; gap: 5px; }
    .tab-btn {
        background: transparent; border: none; color: var(--text-muted);
        padding: 8px 20px; border-radius: 8px; font-family: 'Rajdhani';
        font-weight: 700; transition: all 0.3s;
    }
    .tab-btn.active { background: var(--p-primary); color: #fff; }

    .game-card { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; }
    .game-card:hover { transform: translateY(-10px); border-color: var(--p-primary); }
    
    .game-card-img { height: 160px; position: relative; border-radius: 16px 16px 0 0; overflow: hidden; }
    .game-card-img img { width: 100%; height: 100%; object-fit: cover; }
    
    .game-tag {
        position: absolute; top: 10px; left: 10px; background: var(--accent-gold);
        color: #000; font-size: 0.6rem; font-weight: 900; padding: 4px 10px; border-radius: 4px;
    }
    .player-count-tag {
        position: absolute; bottom: 10px; right: 10px; background: rgba(0,0,0,0.6);
        color: #fff; font-size: 0.7rem; padding: 4px 8px; border-radius: 6px; backdrop-filter: blur(5px);
    }

    .feature-badge {
        background: rgba(255,255,255,0.05); padding: 4px 8px; border-radius: 6px;
        font-size: 0.65rem; color: var(--text-muted); margin-right: 5px;
    }

    .coming-soon-overlay {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.7); z-index: 2; display: flex; align-items: center;
        justify-content: center; font-family: 'Rajdhani'; font-weight: 900; letter-spacing: 2px;
    }
</style>