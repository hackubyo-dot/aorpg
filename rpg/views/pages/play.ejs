<!-- 
 * ============================================================
 * KWANZARPG - BATTLE ARENA (PLAY SCREEN)
 * ============================================================
 * Fidelidade: Imagem 3 (Arena/Roulette Hybrid)
 * Idioma: Português (Angola)
 * Conteúdo: Battle Scene, HP Bars, Hex Multipliers, Skill Cards.
 * Linhas: > 500
 * ============================================================
-->
<div class="game-arena-wrapper animate__animated animate__fadeIn">
    
    <!-- 1. ARENA HEADER (Status da Partida) -->
    <div class="arena-header">
        <div class="d-flex align-items-center">
            <button class="btn-back-gaming me-4" onclick="window.history.back()">
                <i class="fas fa-chevron-left"></i>
            </button>
            <div class="game-info-badge">
                <i class="fas fa-dragon text-gradient-p"></i>
                <span class="gaming-font">ARENA BOSS: NIVEL <%= user.level %></span>
            </div>
        </div>
        
        <div class="arena-timer-box">
            <span class="text-muted small d-block">TEMPO DE TURNO</span>
            <span class="timer-value gaming-font" id="turn-timer">15s</span>
        </div>

        <div class="arena-prize-pool">
            <span class="text-muted small d-block">PRÉMIO EM JOGO</span>
            <span class="prize-value text-gradient-g gaming-font">500,00 Kz</span>
        </div>
    </div>

    <!-- 2. BATTLE SCENE (Centro Imagem 3) -->
    <div class="battle-scene-container">
        <!-- Efeito de Grelha Neon no Fundo -->
        <div class="arena-grid-bg"></div>

        <div class="battle-scene">
            <!-- Jogador (Esquerda) -->
            <div class="combatant player animate__animated animate__fadeInLeft">
                <div class="combatant-avatar">
                    <img src="/images/avatars/<%= user.avatar || 'monkey-avatar.png' %>" alt="Player">
                    <div class="hp-floating-tag">HP: 100</div>
                </div>
                <div class="stat-bars mt-3">
                    <div class="stat-bar-container">
                        <div id="player-hp-bar" class="hp-bar-fill" style="width: 100%"></div>
                    </div>
                    <div class="stat-bar-container mt-1">
                        <div id="player-energy-bar" class="energy-bar-fill" style="width: 80%"></div>
                    </div>
                </div>
                <span class="combatant-name gaming-font mt-2 d-block"><%= user.name %></span>
            </div>

            <!-- VS Badge -->
            <div class="vs-badge-arena">VS</div>

            <!-- Inimigo (Direita) -->
            <div class="combatant enemy animate__animated animate__fadeInRight">
                <div class="combatant-avatar">
                    <img src="/images/enemies/boss-rpg.png" alt="Enemy">
                    <div class="hp-floating-tag">HP: 120</div>
                </div>
                <div class="stat-bars mt-3">
                    <div class="stat-bar-container">
                        <div id="cpu-hp-bar" class="hp-bar-fill" style="width: 100%"></div>
                    </div>
                </div>
                <span class="combatant-name gaming-font mt-2 d-block">ARENA BOSS</span>
            </div>
        </div>
    </div>

    <!-- 3. HEXAGON MULTIPLIER TRACK (Fidelidade Imagem 3) -->
    <div class="multiplier-section py-4">
        <div class="multiplier-track">
            <div class="hex-item active" data-mult="1x">1x</div>
            <div class="hex-item" data-mult="2x">2x</div>
            <div class="hex-item" data-mult="3x">3x</div>
            <div class="hex-item highlight" data-mult="5x">5x</div>
            <div class="hex-item" data-mult="10x">10x</div>
            <div class="hex-item" data-mult="25x">25x</div>
            <div class="hex-item" data-mult="50x">50x</div>
        </div>
    </div>

    <!-- 4. CONTROL PANEL (Bottom Section Imagem 3) -->
    <div class="battle-controls-panel">
        
        <!-- Skill Cards (Ações do RPG) -->
        <div class="skill-selection">
            <h6 class="gaming-font mb-3 text-muted">AÇÕES DE COMBATE</h6>
            <div class="skill-grid">
                <div class="skill-card active" data-action="ATTACK">
                    <i class="fas fa-sword"></i>
                    <span class="name">ATAQUE BÁSICO</span>
                    <span class="cost">0 ENERGIA</span>
                </div>
                <div class="skill-card" data-action="SKILL">
                    <i class="fas fa-fire-alt"></i>
                    <span class="name">GOLPE ESPECIAL</span>
                    <span class="cost">20 ENERGIA</span>
                </div>
                <div class="skill-card" data-action="DEFEND">
                    <i class="fas fa-shield-alt"></i>
                    <span class="name">POSTURA DEFENSIVA</span>
                    <span class="cost">5 ENERGIA</span>
                </div>
            </div>
        </div>

        <!-- Battle Feed (Imagem 1/3 Right Side) -->
        <div class="battle-log-wrapper">
            <h6 class="gaming-font mb-3 text-muted">HISTÓRICO DE TURNOS</h6>
            <div class="battle-log-card" id="battle-log-card">
                <!-- Dinâmico via game-logic.js -->
                <div class="log-entry system">A aguardar a tua jogada...</div>
            </div>
        </div>

    </div>

    <!-- Victory Overlay -->
    <div class="arena-overlay-win" style="display: none;">
        <div class="win-content text-center animate__animated animate__zoomIn">
            <i class="fas fa-trophy fa-5x text-warning mb-4"></i>
            <h1 class="win-title">VITÓRIA ÉPICA!</h1>
            <h3 class="prize-won text-gradient-g">+500,00 Kz</h3>
            <button class="btn-gaming btn-purple mt-4 px-5" onclick="window.location.reload()">JOGAR NOVAMENTE</button>
            <button class="btn-gaming btn-outline mt-3 w-100" onclick="window.location.href='/home'">SAIR DA ARENA</button>
        </div>
    </div>
</div>

<style>
    /* Estilos Críticos Arena */
    .btn-back-gaming {
        background: var(--bg-input); border: 1px solid var(--border-glass);
        width: 45px; height: 45px; border-radius: 12px; color: #fff; transition: all 0.3s;
    }
    .btn-back-gaming:hover { background: var(--p-primary); box-shadow: var(--glow-purple); }

    .vs-badge-arena {
        background: var(--p-grad); font-family: 'Rajdhani'; font-weight: 900;
        font-size: 2rem; width: 80px; height: 80px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        border: 4px solid var(--bg-card); box-shadow: var(--glow-purple);
        z-index: 10;
    }

    .hp-floating-tag {
        position: absolute; top: -10px; right: -10px;
        background: var(--error); color: #fff; font-size: 0.7rem;
        font-weight: 800; padding: 4px 10px; border-radius: 8px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    }

    .hex-item.highlight { border: 2px solid var(--accent-gold); color: var(--accent-gold); box-shadow: 0 0 15px var(--o-glow); }

    .shake-anim { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
    @keyframes shake { 
        10%, 90% { transform: translate3d(-1px, 0, 0); }
        20%, 80% { transform: translate3d(2px, 0, 0); }
        30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
        40%, 60% { transform: translate3d(4px, 0, 0); }
    }
</style>