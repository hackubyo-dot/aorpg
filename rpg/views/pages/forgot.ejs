<!-- 
 * ============================================================
 * KWANZARPG - FORGOT PASSWORD PAGE
 * ============================================================
 * Fidelidade: Imagem 4 (SolanaShuffle Style)
 * Idioma: Português (Angola)
 * Lógica: Ajax-driven via AuthEngine.
 * ============================================================
-->
<!DOCTYPE html>
<html lang="pt-AO">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recuperar Conta | KwanzaRPG Arena</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    
    <link rel="stylesheet" href="/css/theme-core.css">
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body class="auth-page">

    <div id="particles-js" class="auth-bg-effect"></div>

    <div class="auth-container animate__animated animate__zoomIn">
        
        <div class="auth-header">
            <div class="auth-avatar-wrapper">
                <i class="fas fa-unlock-alt fa-3x text-gradient-p"></i>
            </div>
            <h1 class="auth-title gaming-font">Recuperar Acesso</h1>
            <p class="auth-subtitle">Enviaremos um código de verificação para o teu e-mail.</p>
        </div>

        <form id="forgot-form" class="auth-form" novalidate>
            <div class="form-group mb-4">
                <label class="label-gaming">Teu E-mail de Registo</label>
                <div class="position-relative">
                    <i class="fas fa-envelope input-icon"></i>
                    <input type="email" name="email" class="input-gaming" placeholder="exemplo@kwanza.ao" required>
                </div>
            </div>

            <button type="submit" class="btn-gaming btn-purple btn-auth-submit">
                ENVIAR CÓDIGO DE RECUPERAÇÃO
            </button>

            <div class="text-center mt-4">
                <a href="/login" class="text-muted text-decoration-none small fw-bold">
                    <i class="fas fa-arrow-left me-2"></i> VOLTAR AO LOGIN
                </a>
            </div>
        </form>

        <!-- Sucesso de Envio (Hidden initially) -->
        <div id="forgot-success-msg" style="display: none;" class="animate__animated animate__fadeIn">
            <div class="glass-card text-center p-4 border-success">
                <i class="fas fa-paper-plane fa-3x text-success mb-3"></i>
                <h5 class="text-white">E-mail Enviado!</h5>
                <p class="text-muted small">Verifica a tua caixa de entrada (e pasta de spam) para as instruções seguintes.</p>
                <button class="btn-gaming btn-outline w-100" onclick="window.location.href='/login'">VOLTAR AO LOGIN</button>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/auth.js"></script>
    
    <script>
        particlesJS('particles-js', {
            "particles": {
                "number": { "value": 40, "density": { "enable": true, "value_area": 800 } },
                "color": { "value": "#ffffff" },
                "opacity": { "value": 0.1 },
                "move": { "enable": true, "speed": 0.5 }
            }
        });

        // Simulação de submissão para este arquivo
        document.getElementById('forgot-form').addEventListener('submit', function(e) {
            e.preventDefault();
            this.style.display = 'none';
            document.getElementById('forgot-success-msg').style.display = 'block';
        });
    </script>
</body>
</html>