<!-- 
 * ============================================================
 * KWANZARPG - LOGIN PAGE
 * ============================================================
 * Fidelidade: Imagem 4 (SolanaShuffle Style)
 * Idioma: Português (Angola)
 * Lógica: Ajax-driven via AuthEngine.
 * ============================================================
-->
<!DOCTYPE html>
<html lang="pt-AO">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | KwanzaRPG Arena</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    
    <link rel="stylesheet" href="/css/theme-core.css">
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body class="auth-page">

    <!-- Efeito de partículas de fundo -->
    <div id="particles-js" class="auth-bg-effect"></div>

    <div class="auth-container animate__animated animate__zoomIn">
        
        <!-- Header com Avatar (Fidelidade Imagem 4) -->
        <div class="auth-header">
            <div class="auth-avatar-wrapper">
                <img src="/images/avatars/monkey-avatar.png" alt="Kwanza Player">
                <div class="auth-level-badge">17</div>
            </div>
            <h1 class="auth-title gaming-font">Stinger_22 <i class="fas fa-check-circle text-info ms-1" style="font-size: 1rem;"></i></h1>
            <p class="auth-subtitle">Acede à maior arena competitiva de Angola</p>
        </div>

        <!-- Tabs de Navegação (Imagem 4) -->
        <div class="auth-tabs">
            <div class="auth-tab active">ENTRAR</div>
            <div class="auth-tab" onclick="window.location.href='/register'">REGISTAR</div>
        </div>

        <!-- Formulário de Login -->
        <form id="login-form" class="auth-form" novalidate>
            <div class="form-group">
                <label class="label-gaming">E-mail ou Nome de Utilizador</label>
                <div class="position-relative">
                    <i class="fas fa-user input-icon"></i>
                    <input type="email" name="email" class="input-gaming" placeholder="exemplo@kwanza.ao" required>
                </div>
            </div>

            <div class="form-group">
                <label class="label-gaming">Palavra-passe</label>
                <div class="position-relative">
                    <i class="fas fa-lock input-icon"></i>
                    <input type="password" name="password" class="input-gaming" placeholder="**********" required>
                    <i class="fas fa-eye-slash show-password-toggle"></i>
                </div>
                <div class="text-end mt-2">
                    <a href="/forgot-password" class="forgot-link">Esqueceste a palavra-passe?</a>
                </div>
            </div>

            <button type="submit" class="btn-gaming btn-purple btn-auth-submit mt-2">
                ENTRAR NA CONTA
            </button>

            <div class="auth-divider">OU</div>

            <button type="button" class="btn-discord">
                <i class="fab fa-discord fa-lg"></i> ENTRAR COM DISCORD
            </button>
        </form>

        <div class="auth-footer">
            Ainda não tens conta? <a href="/register">Cria a tua agora!</a>
        </div>
    </div>

    <!-- Scripts de Terceiros -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
    
    <!-- Scripts da Plataforma -->
    <script src="/js/main.js"></script>
    <script src="/js/auth.js"></script>

    <script>
        // Inicialização de Partículas de Fundo (Atmospheric vibe)
        particlesJS('particles-js', {
            "particles": {
                "number": { "value": 80, "density": { "enable": true, "value_area": 800 } },
                "color": { "value": "#7b2ff7" },
                "shape": { "type": "circle" },
                "opacity": { "value": 0.2, "random": true },
                "size": { "value": 3, "random": true },
                "line_linked": { "enable": true, "distance": 150, "color": "#7b2ff7", "opacity": 0.1, "width": 1 },
                "move": { "enable": true, "speed": 1, "direction": "none", "random": true, "straight": false, "out_mode": "out" }
            },
            "interactivity": { "events": { "onhover": { "enable": true, "mode": "bubble" } } }
        });
    </script>
</body>
</html>